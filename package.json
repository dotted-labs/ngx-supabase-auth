    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/platform-browser-dynamic": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@ngrx/signals": "^21.0.1",
    "@supabase/supabase-js": "^2.39.7",
    "@tailwindcss/postcss": "^4.0.12",
    "cors": "^2.8.5",
    "daisyui": "^5.0.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "prettier": "^3.5.3",
    "rxjs": "~7.8.0",
    "tailwindcss": "^4.0.12",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.2.0",
    "@angular/cli": "^21.2.0",

  "license": "MIT",
  "bugs": {
    "url": "https://github.com/dotted-labs/ngx-supabase-auth/issues"
  },
  "homepage": "https://github.com/dotted-labs/ngx-supabase-auth#readme",
  "files": [
    "LICENSE",
    "README.md"
  ],
  "dependencies": {
    "@angular/common": "^21.2.0",
